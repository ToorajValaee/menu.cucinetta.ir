# Environment Configuration Example
# Copy changes to wrangler.toml and fill in YOUR values

# Your Cloudflare Account ID
# Find at: https://dash.cloudflare.com/profile/api-tokens
CLOUDFLARE_ACCOUNT_ID=your-account-id-here

# Cloudflare API Token (for wrangler login)
# Create at: https://dash.cloudflare.com/profile/api-tokens
CLOUDFLARE_API_TOKEN=your-api-token-here

# KV Namespace IDs
# Get from: npm run kv:init
KV_NAMESPACE_ID=your-production-namespace-id
KV_NAMESPACE_PREVIEW_ID=your-preview-namespace-id

# Admin Password (CHANGE THIS!)
# Use a strong password: 12+ chars, mixed case, numbers, symbols
ADMIN_PASSWORD=your-secure-password-here

# Example complete wrangler.toml section:
#
# name = "menu-cucinetta"
# type = "javascript"
# account_id = "YOUR_ACCOUNT_ID"
# 
# [[kv_namespaces]]
# binding = "MENU_ITEMS"
# id = "YOUR_NAMESPACE_ID"
# preview_id = "YOUR_PREVIEW_NAMESPACE_ID"
# 
# [vars]
# ADMIN_PASSWORD = "YOUR_SECURE_PASSWORD"
